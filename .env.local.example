# Supabase — usadas pelo cliente Next.js e pelos scripts admin.
# Para baixar tudo automaticamente do Vercel, rode na pasta do projeto:
#   vercel env pull .env.local
#
# (Faça `npm install -g vercel && vercel login` antes, na primeira vez.)

NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# ⚠️ Server-side apenas — usada por scripts/run-sql.mjs.
# Tem privilégios totais. NUNCA exponha no cliente.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
